# Project Copperhead allowlist (unique to this repo — not Eagle / EnterpriseEnv).
#
# Allowlists are baked in at build time — restart `npm run dev` after editing.
# Names MUST start with VITE_ or Vite will not expose them to the app.
# Use commas, semicolons, or newlines between emails (case-insensitive).
# Optional quotes around addresses are stripped: "a@b.com", 'a@b.com'
#
# GitHub Pages: Repository → Settings → Secrets and variables → Actions → Variables
# Create variable VITE_COPPERHEAD_WHITELIST with the Copperhead email list, then push to main.
#
# Example:
# VITE_COPPERHEAD_WHITELIST=you@company.com,teammate@company.com
VITE_COPPERHEAD_WHITELIST=

# Local drafting only. Do NOT set this for production / GitHub Pages builds.
# When true, the sign-in gate is skipped. Leave unset/false to test allowlist locally.
# VITE_DISABLE_AUTH=true
